    "editor.formatOnPaste": false,
    "editor.quickSuggestionsDelay": 0,
    "diffEditor.ignoreTrimWhitespace": false,
    "idf.hasWalkthroughBeenShown": true,
    "idf.espIdfPathWin": "D:/Espressif/frameworks/esp-idf-v5.5.1/",
    "idf.toolsPathWin": "D:\\Espressif",
    "idf.gitPathWin": "D:/Espressif/tools/idf-git/2.44.0/cmd/git.exe",
