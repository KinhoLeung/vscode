            "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe"
        },
        "MSVC PowerShell": {
            "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
            "args": [
                "-NoExit",
                "-Command",
                "& 'C:\\Program Files (x86)\\Microsoft Visual Studio\\2022\\BuildTools\\Common7\\Tools\\Launch-VsDevShell.ps1' -Arch amd64"
            ],
            "icon": "terminal-powershell"
        },
        "ESP-IDF PowerShell": {
            "path": "C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-NoExit",
                "-File",
                "D:\\Espressif\\Initialize-Idf.ps1",
                "-IdfId",
                "esp-idf-f27b302856cbf3a7065694c7cc7f9de5"
            ],
            "icon": "terminal-powershell"
        }
    },
    "terminal.integrated.defaultProfile.windows": "Git Bash",
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.suggest.enabled": true,
    "terminal.integrated.fontSize": 15, // 集成终端字号
    "terminal.integrated.tabs.showActions": "always", // 始终显示“新建终端”按钮旁的“终端拆分”和“终止”按钮
    "terminal.integrated.tabs.showActiveTerminal": "always", // 始终显示活动终端
    "terminal.integrated.rightClickBehavior": "copyPaste", // 集成终端右击时选择光标下方的字词，并打开上下文菜单
    // "terminal.integrated.env.windows": {
    //     "LC_ALL": "zh_CN.UTF-8" // 集成终端编码: zh_CN.UTF-8
    // },
    "window.dialogStyle": "custom",
    "window.commandCenter": true,
    "window.restoreWindows": "all",
    "vscode-office.editorTheme": "Auto",
    "files.autoSave": "afterDelay",
    "files.autoGuessEncoding": true,
    "files.hotExit": "onExitAndWindowClose", // 在会话间记住未保存的文件,允许在退出编辑器时跳过保存提示 onExitAndWindowClose: 退出或窗口关闭时
    "notebook.formatOnCellExecution": true,
    "notebook.formatOnSave.enabled": true,
    "notebook.lineNumbers": "on", // 控制单元格编辑器中行号的显示
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cmake-tools",
        "editor.quickSuggestions": {
            "other": "on",
            "comments": "off",
            "strings": "off"
        }
    },
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cmake-tools",
        "editor.quickSuggestions": {
            "other": "on",
            "comments": "off",
            "strings": "off"
        }
    },
    "[qml]": {
        "editor.defaultFormatter": "theqtcompany.qt-qml"
    },
    "vscode-serial-monitor.customBaudRates": [
        2000000
    ],
    "git.autofetch": true, // 自动从当前 Git 存储库的默认远程库提取提交
    "git.confirmSync": false, // 同步 Git 存储库前确认
    "git.enableSmartCommit": true, // 没有暂存的更改时，直接提交全部
    "git.mergeEditor": true, // 启用三向合并编辑器
    "git.openRepositoryInParentFolders": "always",
    "markdown.extension.completion.enabled": true,
    "markdown.extension.preview.autoShowPreviewToSide": true,
    "qt-ui.customWidgetsDesignerExePath": "D:\\Qt\\6.9.2\\mingw_64\\bin\\designer.exe",
    "qt-core.qtInstallationRoot": "D:\\Qt",
    "qt-cpp.doNotAskForCMakePath": true,
